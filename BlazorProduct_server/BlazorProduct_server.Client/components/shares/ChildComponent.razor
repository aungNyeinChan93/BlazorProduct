

<h3>@props.test?.Name</h3>

<div class="my-2 bg-red-400 p-2">
    <div role="alert" class="border-2 bg-blue-100 p-4 text-blue-900 shadow-[4px_4px_0_0]">
        <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="mt-0.5 size-4">
                <path fill-rule="evenodd" d="M15 8A7 7 0 1 1 1 8a7 7 0 0 1 14 0ZM9 5a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM6.75 8a.75.75 0 0 0 0 1.5h.75v1.75a.75.75 0 0 0 1.5 0v-2.5A.75.75 0 0 0 8.25 8h-1.5Z" clip-rule="evenodd"></path>
            </svg>

            <strong class="block flex-1 leading-tight font-semibold">
               @(props.Message is not null? props.Message : cascadeProps.Message)
            </strong>
            
            <br />
            <hr/>
        </div>
            @if (ChildContent is not null)
            {
                <div class="my-2">
                    @(ChildContent)
                </div>
            }

            <div>
            <button class="btn btn-primary my-2" @onclick="ClickFromParent">Click</button>
            </div>
    </div>

    <div>
        <GrandChildComponent/>
    </div>
</div>




@code
{
    [Parameter]
    public ChildProps props { get; set; } = new();

    [CascadingParameter]
    public ChildProps cascadeProps { get; set; } = new();

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback ClickFromParent { get; set; }
}

