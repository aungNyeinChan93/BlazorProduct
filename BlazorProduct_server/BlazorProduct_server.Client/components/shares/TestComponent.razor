


<div class="@(selectId == test.TestId ? "bg-green-600":"bg-red-600" ) p-2">

    <div  class="@(test.TestId == selectId ? "border border-red-600":"border border-green-600") block border-2 border-black bg-white p-4 shadow-[4px_4px_0_0] hover:bg-yellow-100 focus:ring-2 focus:ring-yellow-300 focus:outline-0 sm:p-6">
        <span class="inline-flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="size-4">
                <path fill-rule="evenodd" d="M4 1.75a.75.75 0 0 1 1.5 0V3h5V1.75a.75.75 0 0 1 1.5 0V3a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2V1.75ZM4.5 6a1 1 0 0 0-1 1v4.5a1 1 0 0 0 1 1h7a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1h-7Z" clip-rule="evenodd"></path>
            </svg>

            <time datetime="2025-04-01" class="text-xs/none font-semibold uppercase">
                @(test.Status ? "Active" : "Inactive")
            </time>
        </span>
        <input type="checkbox" @bind="test.Status"  />

        <br />
        Is Fav: @(isFavorite ? "Fav":"UnFav") 
        <input type="checkbox" @onchange="handleChange" checked="@(isFavorite ? "checked" : null)" />
        <h3 class="mt-1 text-xl font-semibold">
            @test.Name
        </h3>

        <button class="btn btn-primary my-4" @onclick="(arg) => SelectHandle(arg,test.TestId)">Select Test</button>

        <ButtonOneComponent test="test" TestId="@test.TestId" DeleteEvent="DeleteTest" />
            
    </div>

</div>

@code{
    [Parameter]
    public Test test { get; set; } = new();

    [Parameter]
    public EventCallback<Test> DeleteTest { get; set; }

    public bool isFavorite { get; set; } = false;

    [Parameter]
    public int selectId { get; set; }

        [Parameter]
    public EventCallback<bool> AddFav { get; set; }

    private async Task handleChange(ChangeEventArgs args)
    {
        isFavorite = Convert.ToBoolean(args.Value!);
        await AddFav.InvokeAsync((bool)args.Value!);
    }

    [Parameter]
    public EventCallback<int> SelectEvent { get; set; }


    private async Task SelectHandle(MouseEventArgs args ,int id)
    {
        if (args.Type == "click")
        {
            await SelectEvent.InvokeAsync(id);
        }
    }
}