@page "/tests/two"
@using BlazorProduct_server.Client.Models
@using BlazorProduct_server.Client.components.shares
@rendermode InteractiveWebAssembly



<h3>TestTwoComponent</h3>


<div class="grid grid-cols-3 gap-3 p-4">

@foreach (var test in tests)
    {
        <div class="block border-2 border-black bg-white p-4 shadow-[4px_4px_0_0] hover:bg-yellow-100 focus:ring-2 focus:ring-yellow-300 focus:outline-0 sm:p-6">
            <span class="inline-flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="size-4">
                    <path fill-rule="evenodd" d="M4 1.75a.75.75 0 0 1 1.5 0V3h5V1.75a.75.75 0 0 1 1.5 0V3a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2V1.75ZM4.5 6a1 1 0 0 0-1 1v4.5a1 1 0 0 0 1 1h7a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1h-7Z" clip-rule="evenodd"></path>
                </svg>

                <time datetime="2025-04-01" class="text-xs/none font-semibold uppercase">
                    @(test.Status ? "Active":"Inactive") 
                </time>
            </span>
            <input type="checkbox" @bind="@test.Status" />
            <h3 class="mt-1 text-xl font-semibold">
               @test.Name
            </h3>

            <ButtonOneComponent test="test" TestId="@test.TestId" DeleteEvent="DeleteTest" />
            
        </div>
    }
</div>



@code {
    public List<Test> tests { get; set; } = default!;

    protected override void OnInitialized()
    {
        tests =
            [
           new Test
           {
                    TestId = 1,
                    Name = "test one",
                    Status = false,
                    TestPropetries = new List<TestProps>()
                    {
                        new TestProps {TestPropsId = 1,Key = "color",Value="red"},
                        new TestProps {TestPropsId = 2,Key = "style",Value="inner"},
                        new TestProps {TestPropsId = 1,Key = "mode",Value="fast"},
                    }
           },
            new Test
           {
                    TestId = 2,
                    Name = "test Two",
                    Status = false,
                    TestPropetries = new List<TestProps>()
                    {
                        new TestProps {TestPropsId = 1,Key = "color",Value="red"},
                        new TestProps {TestPropsId = 2,Key = "style",Value="inner"},
                        new TestProps {TestPropsId = 1,Key = "mode",Value="fast"},
                    }
           },
    ];
    }

    private void DeleteTest(Test t)
    {
        var test = tests.FirstOrDefault(test => test.TestId == t.TestId);
        tests.Remove(test!);
    }
}
